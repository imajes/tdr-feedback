{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/feedback/**",
              "components/navigation/**",
              "ui_kits/feedback-site/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Montserrat|Source Sans 3|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Montserrat, Source Sans 3, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='AskCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:ask|raisedBy|category|categoryLabel|sentiment|mentions|priority|onClick|style|key|ref|className|style|children)$/]",
        "message": "<AskCard> doesn't accept that prop. Declared props: ask, raisedBy, category, categoryLabel, sentiment, mentions, priority, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='AskCard'] > JSXAttribute[name.name='category'] > Literal[value!=/^(?:specs|balance|features|bugs)$/]",
        "message": "<AskCard> category must be one of 'specs' | 'balance' | 'features' | 'bugs'."
      },
      {
        "selector": "JSXOpeningElement[name.name='AskCard'] > JSXAttribute[name.name='sentiment'] > Literal[value!=/^(?:positive|negative|neutral|mixed)$/]",
        "message": "<AskCard> sentiment must be one of 'positive' | 'negative' | 'neutral' | 'mixed'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|size|color|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, src, size, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|href|icon|iconRight|disabled|style|onClick|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, href, icon, iconRight, disabled, style, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:category|color|children|style|key|ref|className|style|children)$/]",
        "message": "<CategoryBadge> doesn't accept that prop. Declared props: category, color, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryBadge'] > JSXAttribute[name.name='category'] > Literal[value!=/^(?:specs|balance|features|bugs)$/]",
        "message": "<CategoryBadge> category must be one of 'specs' | 'balance' | 'features' | 'bugs'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|value|label|sublabel|accent|style|key|ref|className|style|children)$/]",
        "message": "<MetricCard> doesn't accept that prop. Declared props: icon, value, label, sublabel, accent, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuoteBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:username|avatarSrc|timestamp|children|tone|source|style|key|ref|className|style|children)$/]",
        "message": "<QuoteBlock> doesn't accept that prop. Declared props: username, avatarSrc, timestamp, children, tone, source, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='QuoteBlock'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:positive|negative|neutral)$/]",
        "message": "<QuoteBlock> tone must be one of 'positive' | 'negative' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SentimentBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|count|showDot|style|key|ref|className|style|children)$/]",
        "message": "<SentimentBadge> doesn't accept that prop. Declared props: tone, children, count, showDot, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SentimentBadge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:positive|negative|neutral|mixed)$/]",
        "message": "<SentimentBadge> tone must be one of 'positive' | 'negative' | 'neutral' | 'mixed'."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|href|key|ref|className|style|children)$/]",
        "message": "<NavLink> doesn't accept that prop. Declared props: id, label, href."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
